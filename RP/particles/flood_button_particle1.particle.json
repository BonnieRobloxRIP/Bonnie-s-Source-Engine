{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "brr:flood_button_particle1",
			"basic_render_parameters": {
				"material": "particles_blend",
				"texture": "textures/particle/flood_button_particle1"
			}
		},
		"components": {
			"minecraft:emitter_local_space": {
				"position": true,
				"rotation": true,
				"velocity": true
			},
			"minecraft:emitter_rate_instant": {
				"num_particles": 1
			},
			"minecraft:emitter_lifetime_looping": {
				"active_time": 1
			},
			"minecraft:emitter_shape_point": {},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 1.5
			},
			"minecraft:particle_initial_spin": {
				"rotation": 90
			},
			"minecraft:particle_appearance_billboard": {
				"size": [
					"0.1 + (1 * ((variable.particle_age / variable.particle_lifetime) * (2 - (variable.particle_age / variable.particle_lifetime))))",
					"0.1 + (1 * ((variable.particle_age / variable.particle_lifetime) * (2 - (variable.particle_age / variable.particle_lifetime))))"
				],
				"facing_camera_mode": "direction_z",
				"direction": {
					"mode": "custom",
					"custom_direction": [
						"variable.brr_face_x",
						"variable.brr_face_y",
						"variable.brr_face_z"
					]
				}
			},
			"minecraft:particle_appearance_tinting": {
				"color": {
					"gradient": {
						"0.0": "#ffffffff",
						"0.7": "#ffffffff",
						"1.0": "#00ffffff"
					},
					"interpolant": "variable.particle_age / variable.particle_lifetime"
				}
			}
		}
	}
}